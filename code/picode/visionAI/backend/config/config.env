# This document is used to document the environment variables used by the application.

# Notes
APP_NOTES_NUMBER_MAX=10
APP_NOTES_TITLE_LENGTH_MAX=50
APP_NOTES_CONTENT_LENGTH_MAX=500

# ArangoDB
APP_ARANGODB_HOST=...
APP_ARANGODB_PORT=...
APP_ARANGODB_DATABASE=...
APP_ARANGODB_USER=...
APP_ARANGODB_PASSWORD=...

# Arduino Leonardo (MG996R control)
# APP_ARDUINO_PORT is kept for backward compatibility.
APP_ARDUINO_PORT=/dev/ttyACM0
APP_LEONARDO_PORT=/dev/ttyACM0
APP_LEONARDO_BAUD=115200
APP_LEONARDO_READ_TIMEOUT_S=1.5

# Wrist MG996R sequence (logical angles -90/0/+90 mapped to physical angles)
APP_WRIST_SERVO1_MIN_ANGLE=0
APP_WRIST_SERVO1_CENTER_ANGLE=90
APP_WRIST_SERVO1_MAX_ANGLE=180
APP_WRIST_SERVO1_INVERTED=0
APP_WRIST_SERVO2_MIN_ANGLE=0
APP_WRIST_SERVO2_CENTER_ANGLE=90
APP_WRIST_SERVO2_MAX_ANGLE=180
APP_WRIST_SERVO2_INVERTED=0
APP_WRIST_SERVO1_CMD_TEMPLATE=WRIST1:{angle}
APP_WRIST_SERVO2_CMD_TEMPLATE=WRIST2:{angle}
APP_WRIST_SEQUENCE_STEP_DELAY_MS=500

# Arduino Mega (GRBL / NEMA17 control)
APP_GRBL_PORT=/dev/ttyACM1
APP_GRBL_BAUD=115200
APP_GRBL_READ_TIMEOUT_S=1.5
APP_GRBL_POSTFLOW_ENABLED=0
APP_GRBL_POSTFLOW_SEQUENCE=$X|$H
