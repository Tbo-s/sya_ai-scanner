# This document is used to document the environment variables used by the application.

# Notes
APP_NOTES_NUMBER_MAX=10
APP_NOTES_TITLE_LENGTH_MAX=50
APP_NOTES_CONTENT_LENGTH_MAX=500

# ArangoDB
APP_ARANGODB_HOST=...
APP_ARANGODB_PORT=...
APP_ARANGODB_DATABASE=...
APP_ARANGODB_USER=...
APP_ARANGODB_PASSWORD=...

# Arduino Leonardo (MG996R control)
# APP_ARDUINO_PORT is kept for backward compatibility.
APP_ARDUINO_PORT=/dev/ttyACM0
APP_LEONARDO_PORT=/dev/ttyACM0
APP_LEONARDO_BAUD=115200

# Arduino Mega (GRBL / NEMA17 control)
APP_GRBL_PORT=/dev/ttyACM1
APP_GRBL_BAUD=115200
APP_GRBL_READ_TIMEOUT_S=1.5
APP_GRBL_POSTFLOW_ENABLED=0
APP_GRBL_POSTFLOW_SEQUENCE=$X|$H

# Camera
APP_CAMERA_INDEX=0
APP_PHOTO_STORAGE_DIR=/tmp/sya_photos

# GRBL arm positions (calibrate with manual jog before first use)
APP_GRBL_FEED_RATE=3000
APP_GRBL_FRONT_X=50.0
APP_GRBL_FRONT_Y=100.0
APP_GRBL_BACK_X=50.0
APP_GRBL_BACK_Y=20.0
APP_GRBL_Z_PICKUP=30.0
APP_GRBL_Z_TRAVEL=5.0

# Distance sensor – arm stops when reading drops to this value (cm)
APP_ARM_DISTANCE_THRESHOLD_CM=3

# Wrist servo dwell time after position command (ms)
APP_WRIST_DWELL_MS=600

# AI damage API
APP_AI_DAMAGE_API_URL=http://localhost:4000/api/v1/analyze
APP_AI_DAMAGE_API_MOCK=1

# Scan sequence timeouts (seconds)
APP_GATE_MOVE_TIMEOUT_S=10
APP_TRAY_MOVE_TIMEOUT_S=10
APP_VACUUM_DWELL_S=1.0
APP_LEONARDO_READ_TIMEOUT_S=1.5
