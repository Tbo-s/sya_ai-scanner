[Unit]
Description=SYA scanner backend
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/sya
EnvironmentFile=/home/pi/sya/backend/config/config.env
ExecStart=/home/pi/sya/scripts/pi_run_backend.sh
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
